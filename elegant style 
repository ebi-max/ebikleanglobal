<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elegant Styles & Events</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Navbar -->
    <nav>
        <div class="logo">Elegant Styles & Events</div>
        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#services">Services</a></li>
            <li><a href="#gallery">Gallery</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- Home Section -->
    <section id="home" class="hero">
        <div class="hero-text">
            <h1>Elegant Styles & Events</h1>
            <p>Hair • Makeup • Bridal • Event Decoration</p>
        </div>
    </section>

    <!-- About Section -->
    <section id="about">
        <h2>About Us</h2>
        <p>Elegant Styles & Events provides premium hair styling, makeup, bridal services, and event decoration. We focus on creating unforgettable looks and experiences for every client, ensuring quality, elegance, and professionalism in all we do.</p>
    </section>

    <!-- Services Section -->
    <section id="services">
        <h2>Our Services</h2>
        <div class="service-cards">
            <div class="card">
                <h3>Hair Styling</h3>
                <p>Professional hair services including dreadlocks, braiding, and styling for all occasions.</p>
            </div>
            <div class="card">
                <h3>Makeup & Bridal</h3>
                <p>Bridal and event makeup, personal styling, and glam services to make you shine.</p>
            </div>
            <div class="card">
                <h3>Event Decoration</h3>
                <p>Decoration services for weddings, birthdays, corporate events, and special occasions.</p>
            </div>
            <div class="card">
                <h3>Special Packages</h3>
                <p>Custom surprise packages and tailored event planning solutions to create memorable experiences.</p>
            </div>
        </div>
    </section>

    <!-- Gallery Section -->
    <section id="gallery">
        <h2>Gallery</h2>
        <div class="gallery-grid">
            <img src="images/hero.jpg" alt="Hair Style Example">
            <img src="images/service1.jpg" alt="Makeup Example">
            <img src="images/service2.jpg" alt="Event Decoration Example">
            <img src="images/service3.jpg" alt="Bridal Styling Example">
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
        <h2>Contact / Book a Service</h2>
        <p>Phone: 09131625573 / 09117446453</p>
        <p>Email: <a href="mailto:Kwincyconcept44@gmail.com">Kwincyconcept44@gmail.com</a></p>
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
            <input type="text" name="name" placeholder="Your Name" required>
            <input type="email" name="_replyto" placeholder="Your Email" required>
            <textarea name="message" placeholder="Your Message / Booking Details" required></textarea>
            <button type="submit">Send</button>
        </form>
    </section>

    <footer>
        <p>Built by EbikleanGlobal &copy; 2026</p>
    </footer>
</body>
</html>